<!DOCTYPE html>
<html lang="ja">
<head>
  <title>経理確認 | 経費精算表システム</title>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>
  <main class="container">
    <h1>経理確認待ちの申請</h1>
    <% if (pending.length === 0) { %>
      <p>現在経理確認待ちの申請はありません。</p>
    <% } else { %>
      <table class="report-table">
        <thead>
          <tr>
            <th>日付</th>
            <th>会社</th>
            <th>部署</th>
            <th>氏名</th>
            <th>合計金額</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% pending.forEach(r => { %>
            <tr>
              <td><%= r.report_date %></td>
              <td><%= r.company %></td>
              <td><%= r.department %></td>
              <td><%= r.applicant_name %></td>
              <td class="amount"><%= r.total_amount.toLocaleString() %> 円</td>
              <td><a href="/accounting/<%= r.id %>">確認する</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <h2>確認履歴<%= (dateFrom || dateTo) ? '(絞り込み中)' : '(直近20件)' %></h2>

    <form method="GET" action="/accounting" class="report-header" style="align-items: end;">
      <label>
        日付(から)
        <input type="date" name="date_from" value="<%= dateFrom || '' %>">
      </label>
      <label>
        日付(まで)
        <input type="date" name="date_to" value="<%= dateTo || '' %>">
      </label>
      <div class="form-actions" style="margin-top: 0;">
        <button type="submit" class="secondary-button">絞り込む</button>
        <% if (dateFrom || dateTo) { %>
          <a href="/accounting">条件をクリア</a>
        <% } %>
      </div>
    </form>

    <div class="form-actions" style="display: flex; justify-content: flex-end;">
      <a href="/accounting/export.csv<%= (dateFrom || dateTo) ? ('?date_from=' + (dateFrom || '') + '&date_to=' + (dateTo || '')) : '' %>" class="secondary-button">経理確認済みデータをCSVエクスポート<%= (dateFrom || dateTo) ? '(絞り込み中の期間)' : '' %></a>
    </div>

    <% if (handled.length === 0) { %>
      <p>まだ経理確認の履歴がありません。</p>
    <% } else { %>
      <table class="report-table">
        <thead>
          <tr>
            <th>日付</th>
            <th>氏名</th>
            <th>合計金額</th>
            <th>ステータス</th>
            <th>確認日時</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% handled.forEach(r => { %>
            <tr>
              <td><%= r.report_date %></td>
              <td><%= r.applicant_name %></td>
              <td class="amount"><%= r.total_amount.toLocaleString() %> 円</td>
              <td><span class="status status-<%= r.status %>"><%= r.status === 'accounting_rejected' ? '差戻し' : '経理確認済み' %></span></td>
              <td><%= r.checked_at %></td>
              <td><a href="/accounting/<%= r.id %>">詳細</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>
